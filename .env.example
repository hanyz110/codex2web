# Optional overrides for Codex2Web
HOST=127.0.0.1
PORT=4321

# External mode auth boundary
CODEX2WEB_BASIC_USER=codex2web
CODEX2WEB_BASIC_PASS=change-me-now

# Execution control
# CODEX2WEB_EXECUTION_PROFILE=full-auto
# CODEX2WEB_REMOTE_TRUSTED=false

# Optional Codex binary override
# CODEX2WEB_CODEX_BINARY=/Users/yourname/.bun/bin/codex
